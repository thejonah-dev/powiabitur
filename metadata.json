<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PoWi Abitur 2026 Lern-Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0f1117;
            --card-bg: #1a1d27;
            --primary: #4f8ef7;
            --success: #4ade80;
            --error: #f87171;
            --warning: #fbbf24;
            --text: #e2e8f0;
            --subtext: #94a3b8;
            --card-bg-glass: rgba(26, 29, 39, 0.6);
            --border: rgba(255, 255, 255, 0.08);
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            display: flex;
            height: 100vh;
            overflow: hidden;
        }
        
        /* Navigation */
        nav {
            width: 260px;
            background-color: var(--card-bg);
            padding: 24px 0;
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--border);
            z-index: 10;
        }
        nav h1 {
            font-size: 1.25rem;
            font-weight: 700;
            padding: 0 24px 24px;
            color: var(--primary);
            border-bottom: 1px solid var(--border);
            margin-bottom: 16px;
            letter-spacing: -0.02em;
        }
        nav a {
            color: var(--subtext);
            text-decoration: none;
            padding: 12px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s ease;
            cursor: pointer;
            font-weight: 500;
            font-size: 0.95rem;
            border-right: 3px solid transparent;
        }
        nav a:hover {
            color: var(--text);
            background-color: rgba(255, 255, 255, 0.03);
        }
        nav a.active {
            background-color: rgba(79, 142, 247, 0.1);
            color: var(--primary);
            border-right: 3px solid var(--primary);
        }
        
        /* Main Content */
        main {
            flex: 1;
            overflow-y: auto;
            padding: 40px;
            position: relative;
        }
        .view {
            display: none;
            animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            max-width: 1200px;
            margin: 0 auto;
        }
        .view.active {
            display: block;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        h2 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 8px;
            letter-spacing: -0.02em;
        }
        .subtitle {
            color: var(--subtext);
            margin-bottom: 32px;
            font-size: 1.05rem;
        }

        /* Dashboard */
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
            gap: 24px;
        }
        .countdown {
            background: var(--card-bg-glass);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            padding: 24px 32px;
            border-radius: 16px;
            border: 1px solid var(--border);
            text-align: center;
            box-shadow: 0 4px 24px rgba(0,0,0,0.2);
        }
        .countdown-title {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--subtext);
            margin-bottom: 8px;
            font-weight: 600;
        }
        .countdown-timer {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--primary);
            font-variant-numeric: tabular-nums;
            letter-spacing: -0.02em;
        }
        
        .section-title {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 20px;
            color: var(--text);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        .card {
            background: var(--card-bg-glass);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            padding: 24px;
            border-radius: 16px;
            border: 1px solid var(--border);
            transition: transform 0.2s ease, border-color 0.2s ease;
            display: flex;
            flex-direction: column;
        }
        .card:hover {
            transform: translateY(-4px);
            border-color: rgba(255,255,255,0.15);
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }
        .card-badge {
            font-size: 0.75rem;
            font-weight: 600;
            padding: 4px 8px;
            border-radius: 6px;
            background: rgba(255,255,255,0.1);
            color: var(--subtext);
        }
        .card h3 {
            font-size: 1.1rem;
            font-weight: 600;
            line-height: 1.4;
            flex: 1;
        }
        .progress-container {
            margin-top: auto;
        }
        .progress-text {
            display: flex;
            justify-content: space-between;
            font-size: 0.85rem;
            color: var(--subtext);
            margin-bottom: 8px;
        }
        .progress-bar {
            height: 6px;
            background: rgba(255,255,255,0.05);
            border-radius: 3px;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            width: 0%;
            transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.3s;
        }

        /* Lernzettel */
        .accordion {
            background: var(--card-bg-glass);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: 12px;
            margin-bottom: 16px;
            overflow: hidden;
            transition: border-color 0.2s;
        }
        .accordion:hover {
            border-color: rgba(255,255,255,0.15);
        }
        .accordion-header {
            padding: 20px 24px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 600;
            font-size: 1.1rem;
            background: rgba(255,255,255,0.01);
            user-select: none;
        }
        .accordion-icon {
            transition: transform 0.3s ease;
            color: var(--subtext);
        }
        .accordion.open .accordion-icon {
            transform: rotate(180deg);
        }
        .accordion-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1), padding 0.4s ease;
            background: rgba(0,0,0,0.2);
        }
        .accordion.open .accordion-content {
            padding: 24px;
            max-height: 3000px; /* Large enough to fit content */
        }
        
        /* Content Formatting */
        .content-body h4 {
            font-size: 1.1rem;
            color: var(--primary);
            margin: 24px 0 12px 0;
            font-weight: 600;
        }
        .content-body h4:first-child {
            margin-top: 0;
        }
        .content-body ul {
            margin-left: 24px;
            margin-bottom: 16px;
            color: var(--text);
            line-height: 1.6;
        }
        .content-body li {
            margin-bottom: 8px;
            padding-left: 8px;
        }
        .content-body li::marker {
            color: var(--subtext);
        }

        /* Buttons */
        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 32px;
            padding-top: 24px;
            border-top: 1px solid var(--border);
        }
        .btn {
            background: rgba(255,255,255,0.1);
            color: var(--text);
            border: 1px solid transparent;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.95rem;
            font-weight: 500;
            transition: all 0.2s ease;
            font-family: inherit;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn:hover {
            background: rgba(255,255,255,0.15);
        }
        .btn-primary {
            background: var(--primary);
            color: #fff;
        }
        .btn-primary:hover {
            background: #3b76e3;
        }
        .btn-success {
            background: rgba(74, 222, 128, 0.15);
            color: var(--success);
            border: 1px solid rgba(74, 222, 128, 0.3);
        }
        .btn-success:hover {
            background: rgba(74, 222, 128, 0.25);
        }

        /* Mobile */
        @media (max-width: 768px) {
            body {
                flex-direction: column;
            }
            nav {
                width: 100%;
                flex-direction: row;
                order: 2;
                padding: 12px 8px;
                justify-content: space-between;
                border-right: none;
                border-top: 1px solid var(--border);
                overflow-x: auto;
                padding-bottom: env(safe-area-inset-bottom, 12px);
            }
            nav h1 { display: none; }
            nav a {
                padding: 8px 12px;
                font-size: 0.8rem;
                border-right: none;
                border-bottom: 3px solid transparent;
                flex-direction: column;
                gap: 4px;
                white-space: nowrap;
            }
            nav a:hover, nav a.active {
                background: transparent;
                border-right: none;
                border-bottom: 3px solid var(--primary);
            }
            main {
                order: 1;
                padding: 24px 16px;
            }
            .dashboard-header {
                flex-direction: column;
                align-items: stretch;
            }
            .countdown-timer {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
    <nav>
        <h1>PoWi Abi '26</h1>
        <a class="active" onclick="navigate('dashboard')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"></rect><rect x="14" y="3" width="7" height="5"></rect><rect x="14" y="12" width="7" height="9"></rect><rect x="3" y="16" width="7" height="5"></rect></svg>
            Dashboard
        </a>
        <a onclick="navigate('lernzettel')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            Lernzettel
        </a>
        <a onclick="navigate('karteikarten')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
            Karteikarten
        </a>
        <a onclick="navigate('quiz')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            Quiz
        </a>
        <a onclick="navigate('operatoren')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
            Operatoren
        </a>
        <a onclick="navigate('eroerterung')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            Erörterung
        </a>
        <a onclick="navigate('fortschritt')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
            Fortschritt
        </a>
    </nav>

    <main>
        <!-- Dashboard -->
        <div id="dashboard" class="view active">
            <div class="dashboard-header">
                <div>
                    <h2>Willkommen zurück!</h2>
                    <p class="subtitle">Dein PoWi-Abitur am 17. April 2026 (255 Min.)</p>
                </div>
                <div class="countdown">
                    <div class="countdown-title">Zeit bis zur Prüfung</div>
                    <div class="countdown-timer" id="timer">Lade...</div>
                </div>
            </div>

            <h3 class="section-title">Themenfelder Übersicht</h3>
            <div class="grid" id="topics-grid">
                <!-- Generated by JS -->
            </div>
        </div>

        <!-- Lernzettel -->
        <div id="lernzettel" class="view">
            <h2>Lernzettel</h2>
            <p class="subtitle">Alle relevanten Inhalte für das Abitur 2026</p>
            <div id="accordion-container">
                <!-- Generated by JS -->
            </div>
        </div>
        
        <!-- Placeholders for other views -->
        <div id="karteikarten" class="view">
            <h2>Karteikarten</h2>
            <p class="subtitle">Aktives Lernen durch Spaced Repetition</p>
            <div class="card"><p>Wird im nächsten Schritt implementiert.</p></div>
        </div>
        <div id="quiz" class="view">
            <h2>Quiz</h2>
            <p class="subtitle">Teste dein Wissen in verschiedenen Formaten</p>
            <div class="card"><p>Wird im nächsten Schritt implementiert.</p></div>
        </div>
        <div id="operatoren" class="view">
            <h2>Operatoren-Trainer</h2>
            <p class="subtitle">Lerne, was in den Klausuren wirklich verlangt wird</p>
            <div class="card"><p>Wird im nächsten Schritt implementiert.</p></div>
        </div>
        <div id="eroerterung" class="view">
            <h2>Erörterungs-Builder</h2>
            <p class="subtitle">Strukturiere deine Argumentation Schritt für Schritt</p>
            <div class="card"><p>Wird im nächsten Schritt implementiert.</p></div>
        </div>
        <div id="fortschritt" class="view">
            <h2>Dein Fortschritt</h2>
            <p class="subtitle">Statistiken und Lernkalender</p>
            <div class="card"><p>Wird im nächsten Schritt implementiert.</p></div>
        </div>
    </main>

    <script>
        // Navigation
        function navigate(viewId) {
            document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
            document.getElementById(viewId).classList.add('active');
            
            document.querySelectorAll('nav a').forEach(a => a.classList.remove('active'));
            const target = Array.from(document.querySelectorAll('nav a')).find(a => a.getAttribute('onclick').includes(viewId));
            if(target) target.classList.add('active');
        }

        // Countdown
        function updateCountdown() {
            const examDate = new Date('2026-04-17T09:00:00').getTime();
            const now = new Date().getTime();
            const distance = examDate - now;

            if (distance < 0) {
                document.getElementById('timer').innerText = "Prüfung läuft";
                return;
            }

            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

            document.getElementById('timer').innerText = 
                `${days}t ${hours.toString().padStart(2, '0')}h ${minutes.toString().padStart(2, '0')}m ${seconds.toString().padStart(2, '0')}s`;
        }
        setInterval(updateCountdown, 1000);
        updateCountdown();

        // Data
        const topics = [
            { id: 'q1_1', badge: 'Q1.1', title: 'Verfassung & Rechtsstaatlichkeit', status: 0 },
            { id: 'q1_2', badge: 'Q1.2', title: 'Parteiendemokratie', status: 0 },
            { id: 'q1_4', badge: 'Q1.4', title: 'Öffentlichkeit im Wandel', status: 0 },
            { id: 'q2_1', badge: 'Q2.1', title: 'Konjunktur & Wirtschaftspolitik', status: 0 },
            { id: 'q2_2', badge: 'Q2.2', title: 'Soziale Marktwirtschaft', status: 0 },
            { id: 'q2_4', badge: 'Q2.4', title: 'Arbeitsmarkt & Tarifpolitik', status: 0 },
            { id: 'q3_1', badge: 'Q3.1', title: 'Internationale Konflikte', status: 0 },
            { id: 'q3_2', badge: 'Q3.2', title: 'Weltwirtschaft & Globalisierung', status: 0 },
            { id: 'q3_5', badge: 'Q3.5', title: 'Weltumweltpolitik', status: 0 }
        ];

        const lernzettelContent = {
            'q1_1': `
                <div class="content-body">
                    <h4>Grundprinzipien des GG</h4>
                    <ul>
                        <li>Rechtsstaatsprinzip, Demokratieprinzip, Sozialstaatsprinzip, Bundesstaatsprinzip, Republikprinzip</li>
                    </ul>
                    <h4>Gewaltenteilung</h4>
                    <ul>
                        <li>Legislative (Bundestag/Bundesrat), Exekutive (Bundesregierung), Judikative (BVerfG)</li>
                    </ul>
                    <h4>Wichtige GG-Artikel</h4>
                    <ul>
                        <li>Art. 1 (Menschenwürde), Art. 2 (freie Entfaltung), Art. 3 (Gleichheit), Art. 5 (Meinungsfreiheit), Art. 8 (Versammlungsfreiheit), Art. 9 (Koalitionsfreiheit), Art. 14 (Eigentum), Art. 20 (Staatsprinzipien), Art. 79 (Ewigkeitsklausel), Art. 93 (BVerfG)</li>
                    </ul>
                    <h4>BVerfG</h4>
                    <ul>
                        <li>Aufgaben, Normenkontrolle (abstrakt/konkret), Verfassungsbeschwerde</li>
                    </ul>
                    <h4>EGMR</h4>
                    <ul>
                        <li>Europäischer Gerichtshof für Menschenrechte, Verhältnis zum BVerfG</li>
                    </ul>
                    <h4>Gesetzgebungsprozess</h4>
                    <ul>
                        <li>Initiative → Bundesrat 1. Durchgang → Bundestag (1./2./3. Lesung) → Bundesrat 2. Durchgang → Einspruchs- vs. Zustimmungsgesetz → Vermittlungsausschuss → Bundespräsident → Bundesgesetzblatt</li>
                    </ul>
                    <h4>Spannungsfeld Exekutive/Legislative</h4>
                    <ul>
                        <li>Regierungsdominanz in der Praxis</li>
                    </ul>
                    <h4>EU-Recht und nationales Recht</h4>
                    <ul>
                        <li>Vorrang, Ultra-vires-Doktrin</li>
                    </ul>
                    <h4>Wehrhafte Demokratie</h4>
                    <ul>
                        <li>Parteiverbot (Art. 21 Abs. 2), Verwirkung von Grundrechten (Art. 18), Verfassungsschutz</li>
                    </ul>
                    <h4>Spannungsverhältnis Freiheit vs. Sicherheit</h4>
                    <ul>
                        <li>Sicherheitsgesetze, Überwachung, Verhältnismäßigkeit</li>
                    </ul>
                </div>
            `,
            'q2_1': `
                <div class="content-body">
                    <h4>BIP</h4>
                    <ul>
                        <li>nominal vs. real, Wachstum und Rezession</li>
                    </ul>
                    <h4>Konjunkturzyklus</h4>
                    <ul>
                        <li>Aufschwung → Boom → Abschwung → Rezession (Merkmale jeder Phase)</li>
                    </ul>
                    <h4>Konjunkturindikatoren</h4>
                    <ul>
                        <li>Früh-, Präsens-, Spätindikatoren; Ifo-Index</li>
                    </ul>
                    <h4>Inflation</h4>
                    <ul>
                        <li>Definition, VPI, EZB-Ziel 2%; Ursachen (Nachfrage-, Angebots-, importierte Inflation); Folgen; Deflation und ihre Gefahren</li>
                    </ul>
                    <h4>Keynesianismus</h4>
                    <ul>
                        <li>Grundgedanke, effektive Gesamtnachfrage, Deficit Spending, Multiplikatoreffekt (Formel: 1/(1-c)), Grenzen (Crowding Out, offene VW, Zeitverzug)</li>
                    </ul>
                    <h4>Gesamtnachfrage</h4>
                    <ul>
                        <li>Y = C + I + G + (X-M)</li>
                    </ul>
                    <h4>Fiskalpolitik</h4>
                    <ul>
                        <li>expansiv (Rezession) vs. kontraktiv (Boom); Staatsverschuldung als Problem</li>
                    </ul>
                    <h4>Keynesianismus vs. Angebotspolitik</h4>
                    <ul>
                        <li>Vergleichstabelle (Nachfragesteuerung vs. Angebotsbedingungen)</li>
                    </ul>
                    <h4>EZB</h4>
                    <ul>
                        <li>Mandat, Unabhängigkeit, Instrumente (Leitzins, Offenmarktpolitik, Mindestreserve), Wirkungsmechanismus</li>
                    </ul>
                    <h4>Magisches Viereck</h4>
                    <ul>
                        <li>Preisstabilität, Beschäftigung, Wachstum, außenwirtschaftliches Gleichgewicht</li>
                    </ul>
                </div>
            `
        };

        // Initialize Dashboard
        const grid = document.getElementById('topics-grid');
        topics.forEach(topic => {
            const savedStatus = localStorage.getItem('status_' + topic.id);
            if(savedStatus) topic.status = parseInt(savedStatus);

            let color = 'var(--error)';
            let statusText = 'Nicht begonnen';
            if (topic.status > 0 && topic.status < 100) {
                color = 'var(--warning)';
                statusText = 'In Bearbeitung';
            }
            if (topic.status === 100) {
                color = 'var(--success)';
                statusText = 'Abgeschlossen';
            }

            grid.innerHTML += `
                <div class="card" onclick="navigate('lernzettel'); setTimeout(() => toggleAccordion('${topic.id}', true), 100)" style="cursor: pointer;">
                    <div class="card-header">
                        <span class="card-badge">${topic.badge}</span>
                    </div>
                    <h3>${topic.title}</h3>
                    <div class="progress-container">
                        <div class="progress-text">
                            <span>${statusText}</span>
                            <span>${topic.status}%</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: ${topic.status}%; background-color: ${color};"></div>
                        </div>
                    </div>
                </div>
            `;
        });

        // Initialize Lernzettel
        const accordionContainer = document.getElementById('accordion-container');
        topics.forEach(topic => {
            const content = lernzettelContent[topic.id] || '<div class="content-body"><p style="color: var(--subtext);">Inhalt folgt in der nächsten Iteration.</p></div>';
            
            accordionContainer.innerHTML += `
                <div class="accordion" id="acc_${topic.id}">
                    <div class="accordion-header" onclick="toggleAccordion('${topic.id}')">
                        <span>${topic.badge} – ${topic.title}</span>
                        <svg class="accordion-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </div>
                    <div class="accordion-content">
                        ${content}
                        <div class="actions">
                            <button class="btn btn-success" onclick="markLearned('${topic.id}')">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                Als gelernt markieren
                            </button>
                            <button class="btn btn-primary" onclick="navigate('quiz')">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                                Zum Quiz
                            </button>
                            <button class="btn" onclick="navigate('karteikarten')">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
                                Karteikarten
                            </button>
                        </div>
                    </div>
                </div>
            `;
        });

        function toggleAccordion(id, forceOpen = false) {
            const acc = document.getElementById('acc_' + id);
            if (forceOpen) {
                acc.classList.add('open');
                acc.scrollIntoView({ behavior: 'smooth', block: 'start' });
            } else {
                acc.classList.toggle('open');
            }
        }

        function markLearned(id) {
            localStorage.setItem('status_' + id, '100');
            
            // Show a nice temporary success state on the button
            const btn = event.currentTarget;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Gespeichert!';
            
            setTimeout(() => {
                location.reload(); 
            }, 800);
        }
    </script>
</body>
</html>
